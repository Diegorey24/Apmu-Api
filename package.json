{
  "name": "apmu",
  "version": "1.0.0",
  "main": "main.js",
  "bin": "main.js",
  "scripts": {
    "start": "node main.js",
    "dev": "nodemon main.js",
    "build": "npx @yao-pkg/pkg . --targets node20-win-x64 --output apmu-server.exe --no-bytecode --public --public-packages \"*\""
  },
  "pkg": {
    "assets": [
      "routes/**/*",
      "middlewares/**/*",
      "helpers/**/*",
      "plugins/**/*",
      "models/**/*",
      "config/**/*"
    ],
    "scripts": []
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "md5": "^2.3.0",
    "moment": "^2.30.1",
    "mssql": "^12.5.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1"
  }
}